# Non-secret config contract for all environments
# Dev values can be populated in .env.local (never commit secrets).

# Environment
NODE_ENV=development
APP_ENV=dev

# Azure
AZURE_TENANT_ID=911a2cd5-fcc5-4ccb-ae76-b740c096c559
AZURE_SUBSCRIPTION_ID=5ce30dc6-7731-4317-8540-060abd50d943
AZURE_RESOURCE_GROUP=PLMChanges
AZURE_KEY_VAULT_URI=https://BOMCompareX-kv-dev-001.vault.azure.net/

# OAuth callback base URLs
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
MICROSOFT_CALLBACK_URL=http://localhost:4000/api/auth/microsoft/callback

# Tenant baseline
DEFAULT_TENANT_ID=plmchanges-dev
# Optional JSON map, e.g. {"contoso.com":"tenant-contoso","fabrikam.com":"tenant-fabrikam"}
TENANT_DOMAIN_MAP_JSON=

# Secret names in Azure Key Vault (values are looked up by app)
GOOGLE_CLIENT_ID_SECRET_NAME=google-client-id
GOOGLE_CLIENT_SECRET_SECRET_NAME=google-client-secret
MICROSOFT_CLIENT_ID_SECRET_NAME=microsoft-client-id
MICROSOFT_CLIENT_SECRET_SECRET_NAME=microsoft-client-secret
SQL_CONNECTION_STRING_SECRET_NAME=SqlConnectionString--Dev

# Local fallback only (dev-only; leave blank if using Key Vault integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
DATABASE_URL=

#APP related
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Upload policy overrides (Dev/Test)
# Comma-separated emails that bypass cooldown/credit limits.
# Example: qa1@example.com,qa2@example.com
UPLOAD_UNLIMITED_USER_EMAILS=

# Stage 4 feature flags (rollout controls)
DIFF_ENGINE_V1=true
DIFF_PROGRESSIVE_API_V1=true
NEXT_PUBLIC_RESULTS_GRID_STAGE4_V1=true
# Row-count threshold for async diff start (avoid long synchronous POST /api/diff-jobs on very large BOMs)
DIFF_ASYNC_START_ROW_THRESHOLD=5000

# Stage 7 format-scalability rollout flags
MATCHER_PROFILE_ADAPTERS_V1=true
MATCHER_COMPOSITE_KEY_V1=true
MATCHER_AMBIGUITY_STRICT_V1=true

# Stage 7 core rollout flags
MATCHER_GRAPH_V1=true
RESULTS_TREE_VIEW_V1=true
RESULTS_DYNAMIC_FILTERS_V1=true
NEXT_PUBLIC_RESULTS_TREE_VIEW_V1=true
NEXT_PUBLIC_RESULTS_DYNAMIC_FILTERS_V1=true

# Stage 7 runtime SLO observability flags (off by default)
OBS_S7_TREE_EXPAND_P95=false
OBS_S7_DYNAMIC_QUERY_P95=false
OBS_S7_FIRST_HIERARCHY_RESPONSE=false
OBS_S7_FIRST_MEANINGFUL_TREE_ROWS=false
OBS_S7_OVERHEAD_VS_S4=false

# Stage 5 notification behavior
NOTIFICATIONS_EMAIL_ENABLED=true

#Enables non-production test helper endpoints in the backend for local/e2e testing 
#(for example test login/logout and test admin role grant).
#Keep this false or unset outside local test/dev environments, 
#since these routes bypass normal production onboarding/admin assignment flows.
ENABLE_TEST_ROUTES=true
