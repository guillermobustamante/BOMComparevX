generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model JobRun {
  jobId                                  String    @id @db.NVarChar(64)
  sessionId                              String    @db.NVarChar(64)
  status                                 String    @db.NVarChar(32)
  correlationId                          String    @db.NVarChar(64)
  tenantId                               String    @db.NVarChar(128)
  requestedBy                            String    @db.NVarChar(320)
  createdAtUtc                           DateTime
  idempotencyKey                         String?   @db.NVarChar(256)
  fileAName                              String    @db.NVarChar(512)
  fileASize                              Int
  fileBName                              String    @db.NVarChar(512)
  fileBSize                              Int
  policyComparisonsUsed                  Int
  policyUnrestrictedComparisonsRemaining Int
  policyCooldownUntilUtc                 DateTime?

  @@index([tenantId, requestedBy, createdAtUtc], map: "ix_jobRuns_tenant_user_createdAt")
  @@map("jobRuns")
}

model AppSession {
  sessionId     String   @id @db.NVarChar(191)
  tenantId      String?  @db.NVarChar(191)
  userEmail     String?  @db.NVarChar(320)
  dataJson      String   @db.NVarChar(Max)
  expiresAtUtc  DateTime?
  createdAtUtc  DateTime
  updatedAtUtc  DateTime

  @@index([tenantId, userEmail, updatedAtUtc], map: "ix_appSessions_tenant_user_updatedAt")
  @@index([expiresAtUtc], map: "ix_appSessions_expiresAtUtc")
  @@map("appSessions")
}

model HistoryEntry {
  historyId       String   @id @db.NVarChar(64)
  jobId           String   @unique @db.NVarChar(64)
  sessionId       String   @db.NVarChar(64)
  sessionName     String?  @db.NVarChar(200)
  tagLabel        String?  @db.NVarChar(100)
  createdAtUtc    DateTime
  updatedAtUtc    DateTime
  deletedAtUtc    DateTime?
  deletedBy       String?  @db.NVarChar(320)
  status          String   @db.NVarChar(32)
  initiatorEmail  String   @db.NVarChar(320)
  tenantId        String   @db.NVarChar(128)

  @@index([tenantId, initiatorEmail, createdAtUtc], map: "ix_historyEntries_tenant_user_createdAt")
  @@index([tenantId, deletedAtUtc, createdAtUtc], map: "IX_historyEntries_tenantId_deletedAtUtc_createdAtUtc")
  @@map("historyEntries")
}

model UploadPolicy {
  id               String   @id @db.NVarChar(64)
  tenantId         String   @db.NVarChar(128)
  userKey          String   @db.NVarChar(320)
  comparisonsUsed  Int
  cooldownUntilUtc DateTime?
  updatedAtUtc     DateTime

  @@unique([tenantId, userKey], map: "uq_uploadPolicies_tenant_user")
  @@index([tenantId, userKey, updatedAtUtc], map: "ix_uploadPolicies_tenant_user_updatedAt")
  @@map("uploadPolicies")
}

model UploadEvent {
  eventId         String   @id @db.NVarChar(64)
  tenantId        String   @db.NVarChar(128)
  userKey         String   @db.NVarChar(320)
  eventType       String   @db.NVarChar(64)
  correlationId   String   @db.NVarChar(64)
  detailsJson     String?  @db.NVarChar(Max)
  createdAtUtc    DateTime

  @@index([tenantId, userKey, createdAtUtc], map: "ix_uploadEvents_tenant_user_createdAt")
  @@map("uploadEvents")
}

model AuditLog {
  id              String   @id @db.NVarChar(64)
  timestampUtc    DateTime
  userId          String?  @db.NVarChar(320)
  tenantId        String?  @db.NVarChar(128)
  actionType      String   @db.NVarChar(128)
  resourceType    String?  @db.NVarChar(128)
  resourceId      String?  @db.NVarChar(128)
  detailsJson     String?  @db.NVarChar(Max)
  outcome         String?  @db.NVarChar(64)
  ipAddress       String?  @db.NVarChar(64)
  correlationId   String?  @db.NVarChar(64)

  @@index([tenantId, timestampUtc], map: "ix_auditLogs_tenant_timestamp")
  @@map("auditLogs")
}

model BomColumnMapping {
  mappingId            String   @id @db.NVarChar(64)
  tenantId             String   @db.NVarChar(128)
  bomRevisionId        String   @db.NVarChar(64)
  originalColumnsJson  String   @db.NVarChar(Max)
  canonicalMappingJson String   @db.NVarChar(Max)
  customColumnIndicesJson String? @db.NVarChar(Max)
  detectionConfidence  Float?
  languageMetadataJson String?  @db.NVarChar(Max)
  createdAtUtc         DateTime
  createdBy            String?  @db.NVarChar(320)

  @@index([tenantId, bomRevisionId, createdAtUtc], map: "ix_bomColumnMappings_tenant_revision_createdAt")
  @@map("bomColumnMappings")
}

model UploadedRevision {
  revisionId         String   @id @db.NVarChar(191)
  tenantId           String   @db.NVarChar(191)
  sessionId          String   @db.NVarChar(191)
  jobId              String   @db.NVarChar(191)
  slot               String   @db.NVarChar(32)
  fileName           String   @db.NVarChar(512)
  fileSize           Int
  createdAtUtc       DateTime
  parserMode         String   @db.NVarChar(16)
  sheetName          String   @db.NVarChar(255)
  headersJson        String   @db.NVarChar(Max)
  headerFieldsJson   String   @db.NVarChar(Max)
  headerRowIndex     Int
  dataStartRowIndex  Int
  dataEndRowIndex    Int
  workbookBuffer     Bytes?   @db.VarBinary(Max)
  rowsJson           String   @db.NVarChar(Max)

  @@unique([tenantId, jobId, slot], map: "uq_uploadedRevisions_tenant_job_slot")
  @@index([tenantId, sessionId, createdAtUtc], map: "ix_uploadedRevisions_tenant_session_createdAt")
  @@index([tenantId, revisionId, createdAtUtc], map: "ix_uploadedRevisions_tenant_revision_createdAt")
  @@map("uploadedRevisions")
}

model UploadedRevisionPair {
  pairId           String   @id @db.NVarChar(191)
  tenantId         String   @db.NVarChar(191)
  sessionId        String   @db.NVarChar(191)
  jobId            String   @unique @db.NVarChar(191)
  leftRevisionId   String   @db.NVarChar(191)
  rightRevisionId  String   @db.NVarChar(191)
  createdAtUtc     DateTime

  @@index([tenantId, sessionId, createdAtUtc], map: "ix_uploadedRevisionPairs_tenant_session_createdAt")
  @@index([tenantId, jobId], map: "ix_uploadedRevisionPairs_tenant_job")
  @@map("uploadedRevisionPairs")
}

model ColumnDetectionAudit {
  auditId            String   @id @db.NVarChar(64)
  tenantId           String   @db.NVarChar(128)
  bomRevisionId      String   @db.NVarChar(64)
  sourceColumn       String?  @db.NVarChar(320)
  canonicalField     String?  @db.NVarChar(128)
  strategy           String   @db.NVarChar(64)
  confidence         Float?
  reviewState        String?  @db.NVarChar(64)
  actor              String?  @db.NVarChar(320)
  changedFrom        String?  @db.NVarChar(320)
  changedTo          String?  @db.NVarChar(320)
  timestampUtc       DateTime
  correlationId      String?  @db.NVarChar(64)

  @@index([tenantId, bomRevisionId, timestampUtc], map: "ix_columnDetectionAudits_tenant_revision_timestamp")
  @@map("columnDetectionAudits")
}

model ComparisonShare {
  shareId        String   @id @db.NVarChar(64)
  tenantId       String   @db.NVarChar(128)
  comparisonId   String   @db.NVarChar(64)
  ownerEmail     String   @db.NVarChar(320)
  invitedEmail   String   @db.NVarChar(320)
  permission     String   @db.NVarChar(32)
  createdAtUtc   DateTime
  updatedAtUtc   DateTime
  revokedAtUtc   DateTime?
  createdBy      String?  @db.NVarChar(320)
  revokedBy      String?  @db.NVarChar(320)

  @@unique([tenantId, comparisonId, invitedEmail], map: "uq_comparisonShares_tenant_comparison_invitedEmail")
  @@index([tenantId, ownerEmail, comparisonId], map: "ix_comparisonShares_tenant_owner_comparison")
  @@index([tenantId, invitedEmail, revokedAtUtc], map: "ix_comparisonShares_tenant_invited_revokedAt")
  @@map("comparisonShares")
}

model Notification {
  notificationId       String   @id @db.NVarChar(64)
  tenantId             String   @db.NVarChar(128)
  userEmail            String   @db.NVarChar(320)
  type                 String   @db.NVarChar(64)
  comparisonId         String?  @db.NVarChar(64)
  title                String   @db.NVarChar(320)
  message              String   @db.NVarChar(1024)
  linkPath             String?  @db.NVarChar(1024)
  isRead               Boolean
  createdAtUtc         DateTime
  emailDispatchedAtUtc DateTime?
  detailsJson          String?  @db.NVarChar(Max)

  @@index([tenantId, userEmail, createdAtUtc], map: "ix_notifications_tenant_user_createdAt")
  @@index([tenantId, type, createdAtUtc], map: "ix_notifications_tenant_type_createdAt")
  @@map("notifications")
}

model ExportArtifact {
  artifactId     String   @id @db.NVarChar(64)
  tenantId       String   @db.NVarChar(128)
  comparisonId   String   @db.NVarChar(64)
  requestedBy    String   @db.NVarChar(320)
  format         String   @db.NVarChar(16)
  fileName       String   @db.NVarChar(512)
  byteSize       Int
  createdAtUtc   DateTime

  @@index([tenantId, createdAtUtc], map: "ix_exportArtifacts_tenant_createdAt")
  @@index([tenantId, requestedBy, createdAtUtc], map: "ix_exportArtifacts_tenant_user_createdAt")
  @@map("exportArtifacts")
}

model AdminRoleClaim {
  claimId       String   @id @db.NVarChar(64)
  tenantId      String   @db.NVarChar(128)
  userEmail     String   @db.NVarChar(320)
  role          String   @db.NVarChar(64)
  isActive      Boolean
  createdAtUtc  DateTime
  updatedAtUtc  DateTime
  createdBy     String?  @db.NVarChar(320)

  @@unique([tenantId, userEmail, role], map: "uq_adminRoleClaims_tenant_user_role")
  @@index([tenantId, role, isActive], map: "ix_adminRoleClaims_tenant_role_active")
  @@map("adminRoleClaims")
}

model TenantAliasDecision {
  decisionId              String   @id @db.NVarChar(191)
  tenantId                String   @db.NVarChar(191)
  normalizedSourceColumn  String   @db.NVarChar(255)
  canonicalField          String   @db.NVarChar(191)
  isEnabled               Boolean
  createdAtUtc            DateTime
  updatedAtUtc            DateTime
  updatedBy               String?  @db.NVarChar(320)

  @@unique([tenantId, normalizedSourceColumn, canonicalField], map: "uq_tenantAliasDecisions_tenant_header_field")
  @@index([tenantId, updatedAtUtc], map: "ix_tenantAliasDecisions_tenant_updatedAt")
  @@map("tenantAliasDecisions")
}

model UploadPolicyOverride {
  overrideId     String   @id @db.NVarChar(64)
  tenantId       String   @db.NVarChar(128)
  userKey        String   @db.NVarChar(320)
  isUnlimited    Boolean
  reason         String?  @db.NVarChar(1024)
  createdBy      String?  @db.NVarChar(320)
  createdAtUtc   DateTime
  updatedAtUtc   DateTime

  @@unique([tenantId, userKey], map: "uq_uploadPolicyOverrides_tenant_user")
  @@index([tenantId, isUnlimited, updatedAtUtc], map: "ix_uploadPolicyOverrides_tenant_unlimited_updatedAt")
  @@map("uploadPolicyOverrides")
}

model PartNode {
  nodeId          String   @id @db.NVarChar(64)
  tenantId        String   @db.NVarChar(128)
  revisionId      String   @db.NVarChar(64)
  sourceRowId     String   @db.NVarChar(128)
  partNumber      String?  @db.NVarChar(256)
  revision        String?  @db.NVarChar(128)
  description     String?  @db.NVarChar(512)
  internalId      String?  @db.NVarChar(256)
  hierarchyLevel  Int?
  assemblyPath    String?  @db.NVarChar(1024)
  createdAtUtc    DateTime

  @@unique([tenantId, revisionId, sourceRowId], map: "uq_partNode_tenant_revision_sourceRow")
  @@index([tenantId, revisionId, partNumber], map: "ix_partNode_tenant_revision_partNumber")
  @@index([tenantId, revisionId, createdAtUtc], map: "ix_partNode_tenant_revision_createdAt")
  @@map("partNode")
}

model ContainsEdge {
  edgeId        String   @id @db.NVarChar(64)
  tenantId      String   @db.NVarChar(128)
  revisionId    String   @db.NVarChar(64)
  parentNodeId  String?  @db.NVarChar(64)
  childNodeId   String   @db.NVarChar(64)
  sourceRowId   String   @db.NVarChar(128)
  quantity      Float?
  findNumber    String?  @db.NVarChar(128)
  parentPath    String?  @db.NVarChar(1024)
  depth         Int?
  createdAtUtc  DateTime

  @@unique([tenantId, revisionId, sourceRowId], map: "uq_containsEdge_tenant_revision_sourceRow")
  @@index([tenantId, revisionId, parentNodeId, depth], map: "ix_containsEdge_tenant_revision_parent_depth")
  @@index([tenantId, revisionId, createdAtUtc], map: "ix_containsEdge_tenant_revision_createdAt")
  @@map("containsEdge")
}

model DiffSnapshot {
  snapshotId      String   @id @db.NVarChar(64)
  comparisonId    String   @unique @db.NVarChar(64)
  tenantId        String   @db.NVarChar(128)
  requestedBy     String   @db.NVarChar(320)
  sessionId       String?  @db.NVarChar(64)
  leftRevisionId  String?  @db.NVarChar(64)
  rightRevisionId String?  @db.NVarChar(64)
  contractVersion String   @db.NVarChar(32)
  countersJson    String   @db.NVarChar(Max)
  rowsJson        String   @db.NVarChar(Max)
  createdAtUtc    DateTime

  @@index([tenantId, comparisonId], map: "ix_diffSnapshot_tenant_comparison")
  @@index([tenantId, createdAtUtc], map: "ix_diffSnapshot_tenant_createdAt")
  @@map("diffSnapshot")
}

model ConsentAcceptance {
  consentId      String   @id
  tenantId       String
  userEmail      String
  termsVersion   String
  privacyVersion String
  acceptedAtUtc  DateTime

  @@unique([tenantId, userEmail, termsVersion, privacyVersion], map: "uq_consentAcceptances_tenant_user_versions")
  @@index([tenantId, userEmail, acceptedAtUtc], map: "ix_consentAcceptances_tenant_user_acceptedAt")
  @@index([tenantId, acceptedAtUtc], map: "ix_consentAcceptances_tenant_acceptedAt")
  @@map("consentAcceptances")
}

model TenantIndustrySetting {
  settingId        String   @id
  tenantId         String   @unique
  defaultIndustry  String
  updatedAtUtc     DateTime
  updatedBy        String?

  @@index([tenantId, updatedAtUtc], map: "ix_tenantIndustrySettings_tenant_updatedAt")
  @@map("tenantIndustrySettings")
}

model TenantBomTaxonomy {
  taxonomyId      String   @id
  tenantId        String
  industry        String
  taxonomyJson    String   @db.NVarChar(Max)
  sourceVersion   String
  updatedAtUtc    DateTime
  updatedBy       String?

  @@unique([tenantId, industry], map: "uq_tenantBomTaxonomies_tenant_industry")
  @@index([tenantId, updatedAtUtc], map: "ix_tenantBomTaxonomies_tenant_updatedAt")
  @@map("tenantBomTaxonomies")
}
